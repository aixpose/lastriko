  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
